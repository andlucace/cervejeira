[Unit]
Description=Cervejeira FastAPI service
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/cervejeira/backend
Environment=PATH=/var/www/cervejeira/venv/bin:/usr/bin:/bin
Environment=ALLOWED_ORIGINS=https://your-domain.com
ExecStart=/var/www/cervejeira/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
